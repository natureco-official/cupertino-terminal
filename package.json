{
  "name": "cupertino-terminal",
  "version": "0.1.0",
  "description": "Open-source terminal app that brings the macOS Terminal experience to Windows (WSL supported, bilingual TR/EN UI)",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "electron-store": "^8.2.0",
    "node-datachannel": "^0.12.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "build": {
    "appId": "com.cupertinoterminal.app",
    "productName": "Cupertino Terminal",
    "asarUnpack": [
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**",
      "node_modules/node-datachannel/**"
    ],
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/icon.ico"
    }
  }
}
