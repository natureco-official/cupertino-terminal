{
  "name": "cupertino-terminal",
  "productName": "Cupertino Terminal",
  "version": "0.6.0",
  "description": "Open-source terminal that brings the macOS Terminal look to Windows, macOS and Linux — WSL/zsh, 10 themes, glass/opacity, ZeroLink P2P encrypted remote terminal (SSH-like), bilingual TR/EN UI.",
  "author": "",
  "license": "MIT",
  "keywords": [
    "terminal",
    "tauri",
    "macos",
    "xterm",
    "wsl",
    "zsh",
    "ssh",
    "p2p",
    "remote-terminal",
    "encrypted"
  ],
  "scripts": {
    "start": "tauri dev",
    "frontend:dev": "vite --config vite.config.mjs",
    "frontend:build": "vite build --config vite.config.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "clean": "node scripts/clean.js",
    "test": "node --test test/*.test.js",
    "check": "node --check src/renderer.js && npm test",
    "smoke:tauri": "node scripts/smoke-tauri.js",
    "perf:tauri": "node scripts/benchmark-tauri.js",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.6"
  }
}
