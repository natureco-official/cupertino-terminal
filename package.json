{
  "name": "cupertino-terminal",
  "productName": "Cupertino Terminal",
  "version": "0.2.12",
  "description": "Open-source terminal that brings the macOS Terminal look to Windows, macOS and Linux — WSL/zsh, 10 themes, glass/opacity, ZeroLink P2P encrypted remote terminal (SSH-like), bilingual TR/EN UI.",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "keywords": [
    "terminal",
    "electron",
    "macos",
    "xterm",
    "wsl",
    "zsh",
    "ssh",
    "p2p",
    "remote-terminal",
    "encrypted"
  ],
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "test": "node --test test/*.test.js",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js && npm test",
    "smoke:native": "electron scripts/smoke-native.js"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "node-datachannel": "^0.12.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cupertinoterminal.app",
    "productName": "Cupertino Terminal",
    "npmRebuild": false,
    "afterPack": "build/afterPack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "natureco-official",
        "repo": "cupertino-terminal"
      }
    ],
    "asarUnpack": [
      "node_modules/@homebridge/node-pty-prebuilt-multiarch/**",
      "node_modules/node-datachannel/**"
    ],
    "files": [
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "protocols": [
        {
          "name": "Terminal URL",
          "schemes": [
            "terminal",
            "shell"
          ]
        }
      ],
      "extendInfo": {
        "NSServices": [
          {
            "NSMenuItem": {
              "default": "Cupertino Terminalde Ac"
            },
            "NSMessage": "openFile",
            "NSPortName": "Cupertino Terminal",
            "NSSendTypes": [
              "public.file-url"
            ]
          }
        ]
      }
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cupertino Terminal",
      "runAfterFinish": true
    },
    "dmg": {
      "title": "Cupertino Terminal",
      "icon": "build/icon.png",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "icon": "build/icon.png"
    }
  }
}
