{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cupertino Terminal",
  "version": "0.5.0",
  "identifier": "me.natureco.cupertino-terminal",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../dist-tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cupertino Terminal",
        "width": 1000,
        "height": 650,
        "minWidth": 640,
        "minHeight": 400,
        "center": true,
        "decorations": false,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}
