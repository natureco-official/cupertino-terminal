{
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Cupertino Terminal",
        "width": 1000,
        "height": 650,
        "minWidth": 640,
        "minHeight": 400,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "windowEffects": {
          "effects": [
            "underWindowBackground"
          ]
        }
      }
    ]
  },
  "bundle": {
    "targets": [
      "app",
      "dmg"
    ]
  }
}
